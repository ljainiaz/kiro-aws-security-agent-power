# uv-managed virtual environment for the bundled fetch script.
# Recreated on demand by `uv run --project`; never commit it.
.venv/

# No lockfile: the skill intentionally tracks the latest boto3 for the evolving
# Security Agent API, so don't commit a uv.lock if one gets generated.
uv.lock

# Python caches
__pycache__/
*.pyc
